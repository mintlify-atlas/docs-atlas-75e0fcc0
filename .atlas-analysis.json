  "keyFeatures": [
    "Firecracker microVM isolation for every agent session",
    "Persistent /workspace filesystem across turns and restarts",
    "Credential proxy that hides API keys from agent context",
    "Real-time streaming with SSE events",
    "Sub-second cold starts with pre-provisioned containers",
    "One-command deployment with no configuration",
    "Support for multiple agent frameworks",
    "Encrypted secrets management"
  ],
  "publicApiSurface": [
    "superserve login",
    "superserve deploy",
    "superserve run",
    "superserve init",
    "superserve agents list",
    "superserve agents get",
    "superserve agents delete",
    "superserve secrets set",
    "superserve secrets list",
    "superserve sessions list",
    "superserve sessions end",
    "Superserve(options)",
    "client.run(agentId, options)",
    "client.stream(agentId, options)",
    "client.createSession(agentId, options)",
    "Session.send(message)",
    "AgentStream.on(event, handler)",
    "useAgent(agentId, apiKey)"
  ]
